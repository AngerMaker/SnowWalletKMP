<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background_white"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Disponível"
                android:textColor="#757575"
                android:textSize="12sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/widget_privacy_toggle"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:padding="2dp"
                android:src="@drawable/ic_eye_open"
                android:tint="#757575"
                android:contentDescription="Privacidade" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_balance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="R$ --,--"
            android:textColor="#333333"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/btn_add_income"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/circle_green_bg"
            android:padding="8dp"
            android:src="@drawable/ic_widget_add"
            android:contentDescription="Nova Receita" />

        <ImageView
            android:id="@+id/btn_add_expense"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/circle_red_bg"
            android:padding="8dp"
            android:src="@drawable/ic_widget_remove"
            android:contentDescription="Nova Despesa" />
    </LinearLayout>

    <ImageView
        android:id="@+id/widget_refresh"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone"/>

</RelativeLayout>